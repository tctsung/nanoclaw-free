# NanoClaw Free — single free model, no Claude account. Full guide: docs/nanoclaw-free.md.
# Edit a value? Restart: launchctl kickstart -k gui/$(id -u)/com.nanoclaw (macOS)

# OpenCode Zen — free key at https://opencode.ai/auth
OPENCODE_PROVIDER=opencode
OPENCODE_MODEL=opencode/big-pickle
ANTHROPIC_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_API_KEY=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: TZ_OVERRIDE=Asia/Taipei   •   INSTALL_CJK_FONTS=true
